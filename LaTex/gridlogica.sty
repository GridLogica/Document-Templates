%% gridlogica.sty
%% LaTeX style package for GridLogica publications
%% Compatible with pdfLaTeX and XeLaTeX/LuaLaTeX
%% Usage: \usepackage{gridlogica}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{gridlogica}[2026/05/01 GridLogica Publication Style]

%% ─── Engine detection ────────────────────────────────────────────────────────
\usepackage{iftex}

%% ─── Core packages ───────────────────────────────────────────────────────────
\usepackage[T1]{fontenc}
\usepackage{microtype}
\usepackage{geometry}
\usepackage{xcolor}
\usepackage{titlesec}
\usepackage{titling}
\usepackage{fancyhdr}
\usepackage{enumitem}
\usepackage{booktabs}
\usepackage{hyperref}
\usepackage{parskip}
\usepackage{setspace}
\usepackage{environ}
\usepackage{mdframed}
\usepackage{graphicx}
\usepackage{caption}
\usepackage{abstract}

%% ─── Fonts ───────────────────────────────────────────────────────────────────
\ifXeTeX
  \usepackage{fontspec}
  \setmainfont{DM Serif Display}[
    BoldFont    = DM Serif Display,
    ItalicFont  = DM Serif Display Italic
  ]
  \setsansfont{Lato}[
    UprightFont = *-Light,
    BoldFont    = *-Bold,
    ItalicFont  = *-LightItalic
  ]
  \setmonofont{DM Mono}[
    UprightFont = *-Regular,
    BoldFont    = *-Medium
  ]
\else
  %% pdfLaTeX fallbacks
  \usepackage{lmodern}
  \usepackage[scaled=0.92]{helvet}
  \usepackage{courier}
\fi

%% ─── Page geometry ───────────────────────────────────────────────────────────
\geometry{
  a4paper,
  top    = 30mm,
  bottom = 30mm,
  left   = 32mm,
  right  = 32mm,
  headsep= 10mm
}

%% ─── Colour palette ──────────────────────────────────────────────────────────
\definecolor{glInk}          {HTML}{0f0f0d}
\definecolor{glInkSecondary} {HTML}{3a3a35}
\definecolor{glInkMuted}     {HTML}{7a7a72}
\definecolor{glForestDark}   {HTML}{1a3a2a}
\definecolor{glForestMid}    {HTML}{2c6048}
\definecolor{glForestLight}  {HTML}{d4e8de}
\definecolor{glWarmWhite}    {HTML}{f5f3ed}
\definecolor{glRule}         {HTML}{d4d0c4}
\definecolor{glAmber}        {HTML}{b87333}
\definecolor{glAmberLight}   {HTML}{f0e4d0}

%% ─── Hyperref ────────────────────────────────────────────────────────────────
\hypersetup{
  colorlinks  = true,
  linkcolor   = glForestMid,
  citecolor   = glForestMid,
  urlcolor    = glForestMid,
  pdfborder   = {0 0 0}
}

%% ─── Body text ───────────────────────────────────────────────────────────────
\color{glInk}
\setstretch{1.6}
\setlength{\parskip}{0.75em}
\setlength{\parindent}{0pt}

%% ─── Section headings ────────────────────────────────────────────────────────
%% H1 — DM Serif Display, large
\titleformat{\section}
  {\color{glInk}\fontsize{28}{34}\selectfont}
  {}
  {0em}
  {}
  [\vspace{2pt}\color{glRule}\hrule height 0.5pt\vspace{4pt}]

%% H2 — DM Serif Display, medium
\titleformat{\subsection}
  {\color{glInk}\fontsize{18}{24}\selectfont}
  {}
  {0em}
  {}

%% H3 — Lato Bold, small-caps label style
\titleformat{\subsubsection}
  {\color{glInkSecondary}\sffamily\bfseries\fontsize{10}{14}\selectfont\MakeUppercase}
  {}
  {0em}
  {}

\titlespacing*{\section}      {0pt}{2em}{0.75em}
\titlespacing*{\subsection}   {0pt}{1.5em}{0.5em}
\titlespacing*{\subsubsection}{0pt}{1em}{0.25em}

%% ─── Title block ─────────────────────────────────────────────────────────────
\pretitle{%
  \vspace{-1em}
  {\ttfamily\small\color{glInkMuted}\MakeUppercase{GridLogica Independent Research}}\\[0.5em]
  \fontsize{36}{42}\selectfont\color{glInk}
}
\posttitle{\par}

\preauthor{%
  \vspace{0.4em}
  \sffamily\fontsize{11}{16}\selectfont\color{glInkSecondary}
}
\postauthor{\par}

\predate{%
  \ttfamily\fontsize{10}{14}\selectfont\color{glInkMuted}
}
\postdate{%
  \par\vspace{0.5em}
  \color{glRule}\hrule height 1pt
  \vspace{1.5em}
}

%% ─── Header / footer ─────────────────────────────────────────────────────────
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{%
  \ttfamily\fontsize{9}{12}\selectfont\color{glInkMuted}
  \MakeUppercase{GridLogica} \quad \textperiodcentered \quad \MakeUppercase{\leftmark}
}
\fancyhead[R]{%
  \ttfamily\fontsize{9}{12}\selectfont\color{glInkMuted}
  CC BY-SA 4.0
}
\fancyfoot[C]{%
  \ttfamily\fontsize{9}{12}\selectfont\color{glInkMuted}
  \thepage
}

%% ─── Abstract ────────────────────────────────────────────────────────────────
\renewcommand{\abstractnamefont}{\ttfamily\fontsize{9}{12}\selectfont\color{glInkMuted}\MakeUppercase}
\renewcommand{\abstracttextfont}{\sffamily\fontsize{11}{17}\selectfont\color{glInkSecondary}}
\setlength{\absleftindent}{0pt}
\setlength{\absrightindent}{0pt}

%% ─── Standard-code environment (e.g. S-101-P) ───────────────────────────────
\newcommand{\glStandard}[1]{%
  {\ttfamily\fontsize{10}{14}\selectfont\color{glForestMid} #1}%
}

%% ─── Tag / label pill ────────────────────────────────────────────────────────
\newcommand{\glTag}[2][forest]{%
  \ifstrequal{#1}{forest}{%
    \colorbox{glForestLight}{\ttfamily\fontsize{8}{10}\selectfont\color{glForestDark}\MakeUppercase{#2}}%
  }{}%
  \ifstrequal{#1}{amber}{%
    \colorbox{glAmberLight}{\ttfamily\fontsize{8}{10}\selectfont\color{glAmber}\MakeUppercase{#2}}%
  }{}%
  \ifstrequal{#1}{ink}{%
    \colorbox{glRule}{\ttfamily\fontsize{8}{10}\selectfont\color{glInkSecondary}\MakeUppercase{#2}}%
  }{}%
}

%% ─── Publication card environment ────────────────────────────────────────────
\newmdenv[
  linecolor    = glForestMid,
  linewidth    = 3pt,
  topline      = false,
  rightline    = false,
  bottomline   = false,
  leftline     = true,
  innerleftmargin  = 12pt,
  innerrightmargin = 12pt,
  innertopmargin   = 10pt,
  innerbottommargin= 10pt,
  backgroundcolor  = white
]{glPubCard}

%% ─── Focus area box ──────────────────────────────────────────────────────────
\newmdenv[
  linecolor    = glRule,
  linewidth    = 0.5pt,
  backgroundcolor = glWarmWhite,
  innerleftmargin  = 12pt,
  innerrightmargin = 12pt,
  innertopmargin   = 10pt,
  innerbottommargin= 10pt,
  roundcorner  = 4pt
]{glFocusBox}

%% ─── Blockquote ──────────────────────────────────────────────────────────────
\renewenvironment{quote}{%
  \list{}{%
    \leftmargin  1.5em
    \rightmargin 0pt
    \topsep      0.5em
  }%
  \item\relax
  \itshape\color{glInkSecondary}
}{%
  \endlist
}

%% ─── Lists ───────────────────────────────────────────────────────────────────
\setlist[itemize]{
  leftmargin = 1.5em,
  itemsep    = 0.2em,
  parsep     = 0pt,
  label      = {\color{glForestMid}\textendash}
}

\setlist[enumerate]{
  leftmargin = 1.75em,
  itemsep    = 0.2em,
  parsep     = 0pt,
  label      = {\ttfamily\color{glForestMid}\arabic*.}
}

%% ─── Tables ──────────────────────────────────────────────────────────────────
\renewcommand{\arraystretch}{1.4}
\captionsetup{
  font       = {small, sf},
  labelfont  = {bf, color=glInkSecondary},
  textfont   = {color=glInkMuted},
  labelsep   = period
}

%% ─── Utility commands ────────────────────────────────────────────────────────
%% Mono metadata line (date, standard code)
\newcommand{\glMeta}[1]{%
  {\ttfamily\fontsize{9}{13}\selectfont\color{glInkMuted} #1}%
}

%% Section rule (manual horizontal rule in forest green)
\newcommand{\glRule}{%
  {\color{glForestMid}\hrule height 0.5pt}%
  \vspace{0.5em}%
}

%% Open access footer note
\newcommand{\glOpenAccess}{%
  \vfill
  \noindent{\color{glRule}\hrule height 0.5pt}
  \vspace{0.4em}
  {\ttfamily\fontsize{8}{12}\selectfont\color{glInkMuted}
    \textcopyright{} \the\year{} GridLogica. Published under CC BY-SA 4.0 Open Access.
    \quad gridlogica.org
  }
}

\endinput
